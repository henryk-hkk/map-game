<UserControl x:Class="MapGame.MVVM.Views.Components.RegionPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MapGame.MVVM.Views.Components" xmlns:viewmodels="clr-namespace:MapGame.MVVM.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:MapViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="340">
    <Grid>
        <Border x:Name="RegionInfoPanel"
            Width="340"
            Height="250"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Margin="18,0,0,90"
            Background="#263026"
            BorderBrush="#0B0E0B"
            BorderThickness="3"
            CornerRadius="6"
            Padding="16"
            Visibility="Collapsed">

            <Border.RenderTransform>
                <TranslateTransform x:Name="RegionInfoPanelTransform" X="-360" />
            </Border.RenderTransform>

            <Border.Effect>
                <DropShadowEffect Color="Black"
              BlurRadius="12"
              ShadowDepth="4"
              Opacity="0.55" />
            </Border.Effect>

            <Border.Resources>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#D0C6A6" />
                    <Setter Property="Foreground" Value="#161A14" />
                    <Setter Property="BorderBrush" Value="#11140F" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Margin" Value="6" />
                    <Setter Property="Height" Value="34" />
                    <Setter Property="Cursor" Value="Hand" />
                </Style>
            </Border.Resources>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="RegionNameText"
                   Grid.Row="0"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Text="{Binding SelectedRegion.DisplayName}"
                   Foreground="#E8DEC0"
                   FontSize="22"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,14" />

                <Button Grid.Row="1" Grid.Column="0" Content="{Binding SelectedRegion.Owner.DisplayName}" />
                <Button Grid.Row="2" Grid.Column="0" Content="Roszczenia." />
                <Button Grid.Row="1" Grid.Column="1" Content="{Binding SelectedRegion.Population}" />
                <ItemsControl Grid.Row="2" Grid.Column="1" ItemsSource="{Binding RegionLanguagePercentages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="{Binding Key}" FontWeight="Bold" Width="100"/>

                                <TextBlock Text="{Binding Value}" />
                                <TextBlock Text=" %" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>
