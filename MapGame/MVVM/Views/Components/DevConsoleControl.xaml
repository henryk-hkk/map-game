<UserControl x:Class="MapGame.MVVM.Views.Components.DevConsoleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MapGame.MVVM.Views.Components" xmlns:viewmodels="clr-namespace:MapGame.MVVM.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:DevConsoleViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="600">

    <Border BorderBrush="#313244" BorderThickness="1" Background="#1e1e2e" CornerRadius="5,0,0,5">
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- OBSZAR LOGÓW -->
            <ScrollViewer x:Name="LogScrollViewer" 
                          Grid.Row="0" 
                          VerticalScrollBarVisibility="Auto" 
                          Margin="0,0,0,10">
                <StackPanel x:Name="LogPanel" Margin="5" />
            </ScrollViewer>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <!-- Znak zachęty np. ">" -->
                    <ColumnDefinition Width="*" />
                    <!-- Pole tekstowe -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Przycisk -->
                </Grid.ColumnDefinitions>

                <!-- Tło dla całego paska inputu -->
                <Border Grid.ColumnSpan="3" Background="#181825" CornerRadius="4" />

                <TextBlock Grid.Column="0" 
                           Text=">" 
                           Foreground="#89b4fa" 
                           FontFamily="Consolas" 
                           FontSize="14" 
                           VerticalAlignment="Center" 
                           Margin="10,0,5,0" />

                <TextBox x:Name="InputTextBox" 
                         Grid.Column="1" 
                         Background="Transparent" 
                         Foreground="#cdd6f4" 
                         CaretBrush="#cdd6f4"
                         FontFamily="Consolas" 
                         FontSize="14" 
                         BorderThickness="0" 
                         VerticalContentAlignment="Center" 
                         Margin="5,8,5,8"
                         Text="{Binding CurrentInput, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" 
                                    Command="{Binding ExecuteConsoleCommand}" />
                    </TextBox.InputBindings>
                </TextBox>

                <Button x:Name="SendButton" 
                        Grid.Column="2" 
                        Content="➤" 
                        Foreground="#181825"
                        Background="#89b4fa"
                        BorderThickness="0"
                        FontSize="14"
                        Width="35"
                        Margin="2"
                        Cursor="Hand"
                        Command="{Binding ExecuteConsoleCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>