<Window x:Class="MapGame.MVVM.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MapGame.MVVM.ViewModels"
        xmlns:hx="http://helix-toolkit.org/wpf/SharpDX" Title="Map Engine 3D" Height="1080" Width="1920">

    <Window.DataContext>
        <local:MapViewModel />
    </Window.DataContext>

    <Grid Background="Black">
        <hx:Viewport3DX x:Name="MainViewport" 
                MouseMove="OnViewportMouseMove"
                MouseWheel="OnViewportMouseWheel"
                Camera="{Binding MainCamera}"
                EffectsManager="{Binding EffectsManager}"
                BackgroundColor="#1a1a1a"
                IsRotationEnabled="False" 
                IsMoveEnabled="False"
                IsPanEnabled="False"
                IsZoomEnabled="False"
                ShowViewCube="False"
                ShowCoordinateSystem="False"
         >

            <hx:DirectionalLight3D Direction="-1,-1,-1" Color="White" />
            <hx:AmbientLight3D Color="#404040" />

            <hx:MeshGeometryModel3D Geometry="{Binding TerrainGeometry}" 
                            Material="{Binding TerrainBaseMaterial}"
                            MouseDown3D="OnTerrainMouseDown"
                            CullMode="Back" />

            <hx:MeshGeometryModel3D Geometry="{Binding TerrainGeometry}" 
                            Material="{Binding OverlayMaterial}" 
                            IsHitTestVisible="False"
                            IsTransparent="True" 
                            DepthBias="-10"
                            CullMode="Back" />

            <hx:MeshGeometryModel3D Geometry="{Binding RiverGeometry}" 
                            Material="{Binding RiverMaterial}" 
                            IsHitTestVisible="False"
                            IsTransparent="True" 
                            DepthBias="-50"
                            CullMode="None" />
        </hx:Viewport3DX>

        <Canvas IsHitTestVisible="False">
            <TextBlock x:Name="CursorCoordsText" Foreground="Lime" FontWeight="Bold" FontSize="14"
           Width="400" TextWrapping="NoWrap">
                <TextBlock.RenderTransform>
                    <TranslateTransform x:Name="CursorTransform" />
                </TextBlock.RenderTransform>
            </TextBlock>
        </Canvas>

        <Border x:Name="RegionInfoPanel"
        Width="340"
        Height="190"
        HorizontalAlignment="Left"
        VerticalAlignment="Bottom"
        Margin="18,0,0,90"
        Background="#263026"
        BorderBrush="#0B0E0B"
        BorderThickness="3"
        CornerRadius="6"
        Padding="16"
        Visibility="Collapsed">

            <Border.RenderTransform>
                <TranslateTransform x:Name="RegionInfoPanelTransform" X="-360" />
            </Border.RenderTransform>

            <Border.Effect>
                <DropShadowEffect Color="Black"
                          BlurRadius="12"
                          ShadowDepth="4"
                          Opacity="0.55" />
            </Border.Effect>

            <Border.Resources>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#D0C6A6" />
                    <Setter Property="Foreground" Value="#161A14" />
                    <Setter Property="BorderBrush" Value="#11140F" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Margin" Value="6" />
                    <Setter Property="Height" Value="34" />
                    <Setter Property="Cursor" Value="Hand" />
                </Style>
            </Border.Resources>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="RegionNameText"
                   Grid.Row="0"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Text="Kraj"
                   Foreground="#E8DEC0"
                   FontSize="22"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,14" />

                <Button Grid.Row="1" Grid.Column="0" Content="Pop." />
                <Button Grid.Row="2" Grid.Column="0" Content="Narod" />
                <Button Grid.Row="1" Grid.Column="1" Content="Owner" />
                <Button Grid.Row="2" Grid.Column="1" Content="Rosze." />
            </Grid>
        </Border>

    </Grid>
</Window>